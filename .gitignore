# ==========================================
# Terraform / Cloud Architecture
# ==========================================
# Local .terraform directories containing binaries
.terraform/

# Hide local variable files (secrets, keys, unique deployment variables)
*.tfvars
*.tfvars.json

# Ignore local execution plan overrides and temporary state files
*tfplan*
*.tfstate
*.tfstate.*

# Backup files generated by manual state alterations
*.backup

# Crash logs
crash.log
crash.*.log

# ==========================================
# Benchmarking & Load Test Analytics
# ==========================================
# Blocks heavy k6/CloudWatch JSON output logs from polluting Git history
loadtests/results/
results/*.json
*.json.gz

# ==========================================
# Node.js Container App
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# Python Lambda App
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.venv
venv/
ENV/

# Exclude the automated compilation zip bundles
app/lambda/build/
*.zip

# ==========================================
# Operating System & IDE Overhead
# ==========================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp